@echo off
setlocal

set "WEBOTS_DEV_BINARY_DIR=@WEBOTS_DEV_BINARY_DIR@"
set "WEBOTS_DEV_EXECUTABLE=@WEBOTS_DEV_EXECUTABLE@"
set "WEBOTS_DEV_PKG_CONFIG_PATH=@WEBOTS_DEV_PKG_CONFIG_PATH@"

set "WEBOTS_HOME=@WEBOTS_DEV_HOME@"
set "WEBOTS_CONTROLLER_LIB_PATH=@WEBOTS_DEV_CONTROLLER_LIB_PATH@"
set "WEBOTS_CONTROLLER_C_LIB=@WEBOTS_DEV_CONTROLLER_C_LIB@"
set "WEBOTS_CONTROLLER_CPP_LIB=@WEBOTS_DEV_CONTROLLER_CPP_LIB@"
set "WEBOTS_LIB_PATH=@WEBOTS_DEV_LIB_PATH@"

set "PKG_CONFIG_PATH=%WEBOTS_DEV_PKG_CONFIG_PATH%;%PKG_CONFIG_PATH%"
set "PATH=@WEBOTS_DEV_CMD_PATH@;%PATH%"

if "%~1"=="" goto launch_webots
if exist "%~1" goto launch_webots_with_args
goto run_command

:launch_webots
"%WEBOTS_DEV_EXECUTABLE%"
exit /b %ERRORLEVEL%

:launch_webots_with_args
"%WEBOTS_DEV_EXECUTABLE%" %*
exit /b %ERRORLEVEL%

:run_command
%*
exit /b %ERRORLEVEL%
