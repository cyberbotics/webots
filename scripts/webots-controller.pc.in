prefix=@WEBOTS_PC_PREFIX@
exec_prefix=@WEBOTS_PC_EXEC_PREFIX@
libdir=@WEBOTS_PC_LIBDIR@
includedir=@WEBOTS_PC_INCLUDEDIR@
controller_c_includedir=@WEBOTS_PC_CONTROLLER_C_INCLUDEDIR@

Name: Webots controller
Description: Webots C controller library
Version: @WEBOTS_VERSION@
Libs: -L${libdir} -lController
Cflags: -I${includedir} -I${controller_c_includedir}
